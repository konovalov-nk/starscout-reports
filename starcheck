#!/usr/bin/env python3
"""
starcheck — single-repo GitHub star forensics tool.
Fetches star data via GitHub API (cached locally), computes metrics,
and generates an HTML report.

Usage:
  ./starcheck <owner/repo>
  ./starcheck --serve        # serve the report directory via HTTP
  GITHUB_TOKEN=ghp_xxx ./starcheck owner/repo
"""

import json, os, sys, time, re
import hashlib, pathlib
from datetime import datetime, timezone
from collections import Counter

CACHE_DIR = pathlib.Path(__file__).parent / ".starcheck_cache"
REPORTS_DIR = pathlib.Path(__file__).parent / "starcheck_reports"
GITHUB_TOKEN = os.environ.get("GITHUB_TOKEN") or ""
CACHE_TTL = 3600  # 1 hour

os.makedirs(CACHE_DIR, exist_ok=True)
os.makedirs(REPORTS_DIR, exist_ok=True)

def gh_api(path: str) -> dict | list:
    """Single GitHub API call."""
    import urllib.request
    url = f"https://api.github.com{path}"
    headers = {"User-Agent": "starcheck"}
    if GITHUB_TOKEN:
        headers["Authorization"] = f"Bearer {GITHUB_TOKEN}"
    req = urllib.request.Request(url, headers=headers)
    with urllib.request.urlopen(req, timeout=10) as r:
        return json.loads(r.read())

def gh_api_paginate(path: str, accept: str = "", max_pages: int = 50) -> list[dict]:
    """Paginate through list endpoints."""
    import urllib.request
    results = []
    page = 1
    while True:
        sep = "&" if "?" in path else "?"
        url = f"https://api.github.com{path}{sep}page={page}"
        headers = {"User-Agent": "starcheck"}
        if GITHUB_TOKEN:
            headers["Authorization"] = f"Bearer {GITHUB_TOKEN}"
        if accept:
            headers["Accept"] = accept
        req = urllib.request.Request(url, headers=headers)
        try:
            with urllib.request.urlopen(req, timeout=8) as r:
                data = json.loads(r.read())
        except Exception:
            break
        if not data:
            break
        results.extend(data)
        if len(data) < 100:
            break
        page += 1
        if page > max_pages:
            break
        time.sleep(0.02)
    return results

def cache_key(repo: str, name: str) -> pathlib.Path:
    safe = repo.replace("/", "_")
    return CACHE_DIR / f"{safe}_{name}.json"

def load_cache(repo: str, name: str) -> dict | None:
    p = cache_key(repo, name)
    if p.exists():
        data = json.loads(p.read_text())
        if time.time() - data.get("_ts", 0) < CACHE_TTL:
            return data
    return None

def save_cache(repo: str, name: str, data):
    data["_ts"] = time.time()
    cache_key(repo, name).write_text(json.dumps(data, default=str))

def get_repo_info(repo: str) -> dict:
    cached = load_cache(repo, "info")
    if cached:
        return cached
    data = gh_api(f"/repos/{repo}")
    save_cache(repo, "info", data)
    return data

def get_star_timeline(repo: str) -> Counter:
    cached = load_cache(repo, "timeline")
    if cached:
        return Counter(cached["dates"])
    stars = gh_api_paginate(
        f"/repos/{repo}/stargazers?per_page=100",
        accept="application/vnd.github.v3.star+json",
        max_pages=200
    )
    dates = Counter()
    for s in stars:
        if s.get("starred_at"):
            dates[s["starred_at"][:10]] += 1
    save_cache(repo, "timeline", {"dates": dict(dates)})
    return dates

def get_stargazer_logins(repo: str, max_sample: int = 10000) -> list[str]:
    cached = load_cache(repo, "logins")
    if cached:
        return cached["logins"][:max_sample]
    stars = gh_api_paginate(f"/repos/{repo}/stargazers?per_page=100", max_pages=100)
    logins = [s["login"] for s in stars if "login" in s][:max_sample]
    save_cache(repo, "logins", {"logins": logins})
    return logins

def get_user_profiles(logins: list[str], max_n: int = 200) -> list[dict]:
    cached = load_cache("_batch", hashlib.md5(str(logins[:max_n]).encode()).hexdigest()[:12])
    if cached:
        return cached["profiles"]
    results = []
    for login in logins[:max_n]:
        time.sleep(0.08)
        try:
            u = gh_api(f"/users/{login}")
            results.append(u)
        except:
            pass
    save_cache("_batch", hashlib.md5(str(logins[:max_n]).encode()).hexdigest()[:12], {"profiles": results})
    return results

def analyze(repo: str) -> dict:
    info = get_repo_info(repo)
    if "message" in info:
        return {"error": info["message"]}

    timeline = get_star_timeline(repo)
    logins = get_stargazer_logins(repo)
    profiles = get_user_profiles(logins)

    now = datetime(2026, 6, 20)
    age_buckets = {"0-1yr": 0, "1-3yr": 0, "3-5yr": 0, "5-10yr": 0, "10-15yr": 0, "15+yr": 0}
    ages = []
    zero_repos = zero_followers = zero_all = low_qual = 0
    for u in profiles:
        if "created_at" not in u: continue
        created = datetime.fromisoformat(u["created_at"][:10])
        age = (now - created).days / 365.25
        ages.append(age)
        if age < 1: age_buckets["0-1yr"] += 1
        elif age < 3: age_buckets["1-3yr"] += 1
        elif age < 5: age_buckets["3-5yr"] += 1
        elif age < 10: age_buckets["5-10yr"] += 1
        elif age < 15: age_buckets["10-15yr"] += 1
        else: age_buckets["15+yr"] += 1
        repos = u.get("public_repos", 0)
        followers = u.get("followers", 0)
        if repos == 0: zero_repos += 1
        if followers == 0: zero_followers += 1
        if repos == 0 and followers == 0: zero_all += 1
        if repos <= 1 and followers <= 2: low_qual += 1

    n_profiles = len(profiles)
    total_stars = info.get("stargazers_count", 0)
    api_stars = sum(timeline.values())

    # Market pricing tiers (from CMU 2026 paper)
    market_max_age_yrs = 5
    market_buyable = sum(v for k, v in age_buckets.items()
                          if float(k.split("-")[0].split("+")[0]) < market_max_age_yrs
                          or k == "3-5yr")
    # Actually let's just sum 0-1yr + 1-3yr + 3-5yr
    buyable_pct = (age_buckets["0-1yr"] + age_buckets["1-3yr"] + age_buckets["3-5yr"]) / max(n_profiles, 1) * 100
    buyable_cost_low = total_stars * buyable_pct / 100 * 0.03  # bot price
    buyable_cost_high = total_stars * buyable_pct / 100 * 0.85  # premium price

    return {
        "repo": repo,
        "total_stars": total_stars,
        "api_stars": api_stars,
        "forks": info.get("forks_count", 0),
        "open_issues": info.get("open_issues_count", 0),
        "watchers": info.get("subscribers_count", 0),
        "created_at": info.get("created_at", "")[:10],
        "description": info.get("description", ""),
        "language": info.get("language", ""),
        "topics": info.get("topics", []),
        "fork_star_ratio": round(info.get("forks_count", 0) / max(total_stars, 1) * 100, 1),
        "watcher_star_ratio": round(info.get("subscribers_count", 0) / max(total_stars, 1) * 100, 1),
        "star_timeline": dict(timeline),
        "n_stargazer_sample": n_profiles,
        "age_buckets": age_buckets,
        "zero_repos_pct": round(zero_repos / max(n_profiles, 1) * 100, 1),
        "zero_followers_pct": round(zero_followers / max(n_profiles, 1) * 100, 1),
        "empty_accounts_pct": round(zero_all / max(n_profiles, 1) * 100, 1),
        "low_quality_pct": round(low_qual / max(n_profiles, 1) * 100, 1),
        "buyable_pct": round(buyable_pct, 1),
        "buyable_cost_low": round(buyable_cost_low),
        "buyable_cost_high": round(buyable_cost_high),
    }

def generate_html(d: dict) -> str:
    if "error" in d:
        return f"<html><body><h1>Error</h1><p>{d['error']}</p></body></html>"

    tl = d["star_timeline"]
    tl_keys = json.dumps(list(tl.keys()))
    tl_vals = json.dumps(list(tl.values()))
    ab = d["age_buckets"]
    ab_labels = json.dumps(list(ab.keys()))
    ab_vals = json.dumps(list(ab.values()))
    ab_pcts = json.dumps([round(v/d["n_stargazer_sample"]*100,1) for v in ab.values()])

    stars_total = d["total_stars"]
    buyable_count = round(stars_total * d["buyable_pct"] / 100)
    beyond_market = stars_total - buyable_count

    return f"""<!DOCTYPE html>
